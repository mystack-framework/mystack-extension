{
  "scopeName": "mystack.injected.php",
  "injectionSelector": "L:source.php",
  "patterns": [
    {
      "match": "(?i)\\b(PHAI|PHAP|PHAU|PHCD|PHCO|PHCS|PHDB|PHDE|PHED|PHEM|PHEV|PHJC|PHJS|PHJT|PHLS|PHML|PHOB|PHOP|PHPA|PHQR|PHRO|PHRQ|PHSE|PHTM|PHTP|PHTR|PHUI|PHVD|DIR|Importer)\\b",
      "name": "support.class.mystack"
    },
    {
      "match": "(?i)\\b(PHUI|PHML|PHJS|PHCS|PHRO|PHDB|PHVD|PHAP|PHRQ|PHJC|PHPA)::([a-zA-Z0-9_]+)\\b",
      "captures": {
        "1": {
          "name": "support.class.mystack"
        },
        "2": {
          "name": "support.function.mystack"
        }
      }
    },
    {
      "match": "\\{\\{[a-zA-Z0-9_\\|]+\\}\\}",
      "name": "variable.other.mystack"
    },
    {
      "match": "(?<=tjs\\(['\"])(.*?)(?=['\"]\\))",
      "name": "string.regexp.mystack"
    }
  ]
}
